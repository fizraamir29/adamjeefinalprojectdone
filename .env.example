# ─────────────────────────────────────────────────────────────
# ADAMJEE COMPUTERS — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git — it is already in .gitignore
# ─────────────────────────────────────────────────────────────

# ── MongoDB ───────────────────────────────────────────────────
# Get connection string from: https://cloud.mongodb.com
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>
MONGO_URI=

# ── JWT Authentication ────────────────────────────────────────
# Use a long random string (32+ characters)
JWT_SECRET=
JWT_EXPIRE=7d

# ── AI Chatbot API Key ────────────────────────────────────────
# Get from: https://openrouter.ai/keys
OPENAI_API_KEY=
VITE_OPENROUTER_API_KEY=

# ── App URL ───────────────────────────────────────────────────
# Development: http://localhost:3000
# Production:  https://your-vercel-domain.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Safepay Payment Gateway ───────────────────────────────────
# Sandbox: https://sandbox.getsafepay.com
# Live:    https://getsafepay.pk
SAFEPAY_MODE=sandbox
SAFEPAY_SECRET_KEY=
SAFEPAY_PUBLIC_KEY=
